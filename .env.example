# Port the main llm-sizer Vite app listens on (default: 4173)
LLM_SIZER_PORT=4173

# Port the Fastify dashboard backend listens on (default: 3001)
DASHBOARD_PORT=3001

# Set this to the dashboard backend URL to enable the Server Dashboard tab
# in the main UI. Must be reachable from the browser (not the container network).
# Example: http://10.216.113.177:3001
VITE_DASHBOARD_URL=

# Dashboard polling interval in milliseconds (default: 5000)
POLL_INTERVAL=5000

# Host Docker group GID. Find with: getent group docker | cut -d: -f3
# If the group name "docker" resolves correctly on your host you can leave this.
DOCKER_GID=docker
